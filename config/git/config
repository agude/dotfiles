[user]
    name = Alexander Gude
    email = alex.public.account@gmail.com

[color]
    branch = auto
    diff = auto
    interactive = auto

[color "status"]
    added = green
    changed = yellow bold
    untracked = red bold

[core]
    editor = nvim
    excludesfile = ~/.config/git/ignore

[merge]
    tool = meld
    ff = only
    conflictstyle = zdiff3

[push]
    default = simple
    followTags = true
    autoSetupRemote = true
    useForceIfIncludes = true

[pull]
    rebase = true

[diff]
    renames = copies
    mnemonicprefix = true
    algorithm = histogram
    colorMoved = default

[log]
    date = iso
    decorate = full

[include]
    path = ~/.gitconfig_local

[alias]
    fpush = push --force-with-lease
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
    prune = fetch --prune
    undo = reset --mixed HEAD~1
    prune-all = fetch --prune --all
    nuke = "!f() { git push origin --delete \"$1\"; }; f"
    # From https://haacked.com/archive/2014/07/28/github-flow-aliases/
    default = !git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@'
    up = !git pull --rebase --prune $@ && git submodule update --init --recursive
    bclean = "!f() { DEFAULT=$(git default); git branch --merged ${1-$DEFAULT} | grep -v \" ${1-$DEFAULT}$\" | xargs git branch -d; }; f"
    bdone = "!f() { DEFAULT=$(git default); git checkout ${1-$DEFAULT} && git up && git bclean ${1-$DEFAULT}; }; f"
    secure-commit = "!f() { for arg in \"$@\"; do if [ \"$arg\" = \"-n\" ] || [ \"$arg\" = \"--no-verify\" ]; then echo \"❌ Security Violation: --no-verify is forbidden.\"; exit 1; fi; done; git commit \"$@\"; }; f"

[branch]
    autosetuprebase = always
    sort = -committerdate

[transfer]
    fsckobjects = true

[stash]
    showPatch = true

[rebase]
    autostash = true
    updateRefs = true

[commit]
    verbose = true

[init]
    defaultBranch = main
[fetch]
    prune = true

[help]
    autocorrect = prompt

[column]
    ui = auto

[rerere]
    enabled = true
